# Copy to .env (which is gitignored). OpenAI is optional but unlocks better
# anomaly summaries and PDF executive summaries. Copernicus / CDSE creds are
# used by the data-science pipeline that exports `data/outputs/*`.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CDSE_USERNAME=
CDSE_PASSWORD=
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
