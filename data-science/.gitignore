# Partner data — never commit raw or processed partner files
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Allow European open-data outputs (no PII, no partner data)
!data/processed/europe/
data/processed/europe/*.parquet

# Outputs are large — keep only tracked GeoJSON committed if desired
data/outputs/*.pkl
data/outputs/*.parquet

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual envs
venv/
.venv/
env/
.env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# macOS
.DS_Store

# IDEs
.vscode/
.idea/

# Logs
*.log
logs/
